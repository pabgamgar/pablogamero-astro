---
import type { CollectionEntry } from "astro:content";
import fs from "node:fs";
import path from "node:path";
import MainLayout from "./MainLayout.astro";
import PostTile from "@/components/PostTile.astro";

interface Props {
    project: CollectionEntry<"projects" | "proyectos">;
    lang: "en" | "es";
    relatedPosts?: CollectionEntry<"blog" | "blog_es">[];
}

const { project, lang } = Astro.props;
const { id: slug, data } = project;
const { name, title, description, links } = data;
const descriptionText = Array.isArray(description)
    ? description.join(" ")
    : description;
const metaDescription = Array.isArray(description)
    ? description[0]
    : description;
const relatedPosts = Astro.props.relatedPosts ?? [];

const imageBase = `${slug}-show`;
const defaultImage = `${imageBase}.webp`;
const langVariant = `${imageBase}-${lang}.webp`;
const publicImagesDir = path.resolve(process.cwd(), "public", "images");
const langVariantPath = path.join(publicImagesDir, langVariant);
const imageSrc = fs.existsSync(langVariantPath)
    ? `/images/${langVariant}`
    : `/images/${defaultImage}`;
const imageDimensions: Record<string, { width: number; height: number }> = {
    caredose: { width: 5760, height: 3240 },
    dibs: { width: 1920, height: 1080 },
    "folders.sh": { width: 2048, height: 1274 },
    itsfree: { width: 2048, height: 1280 },
    limero: { width: 2048, height: 1285 },
    pubmefy: { width: 2048, height: 1280 },
    submoney: { width: 1920, height: 1080 },
};
const { width: imageWidth, height: imageHeight } = imageDimensions[slug] ?? {
    width: 1280,
    height: 720,
};
---

<MainLayout
    title={`${name}${title ? `: ${title}` : ""} • Pablo Gamero`}
    desc={metaDescription}
    kw={name}
    canon={`https://pablogamero.com${lang === "en" ? "/projects" : "/es/proyectos"}/${slug}`}
    alt={`https://pablogamero.com${lang === "en" ? "/es/proyectos" : "/projects"}/${slug}`}
    lang={lang}
    socialImage={imageSrc}
    twitterCard="summary_large_image"
>
    <article
        class="text-white max-w-4xl flex flex-col gap-8 self-center px-4 sm:px-8 md:px-12 py-4"
    >
        <section id="hero" class="w-full flex flex-col gap-4">
            <h1 class="font-bold text-pretty flex gap-4 items-center">
                {name}{title && `: ${title}`}
            </h1>
            <p class="text-pretty text-neutral-300">{descriptionText}</p>
            <div class="w-full aspect-video overflow-clip rounded-xl">
                <img
                    src={imageSrc}
                    alt={name}
                    width={imageWidth}
                    height={imageHeight}
                    class="object-cover w-full h-full object-top"
                    transition:name={`img-${slug}`}
                    loading="eager"
                    fetchpriority="high"
                />
            </div>
            <div class="flex gap-4">
                {
                    Object.entries(links).map(([name, link]) => (
                        <a
                            href={link}
                            class="flex items-center justify-center rounded-lg
                            border border-white/15
                            bg-white/[0.03]
                            hover:border-white/25
                            hover:bg-white/[0.05] transition-all duration-300 px-3 py-1"
                        >
                            {name}
                        </a>
                    ))
                }
            </div>
        </section>
        <section id="content" class="flex flex-col gap-4">
            <slot />
        </section>
        <div class="project-divider" aria-hidden="true"></div>
        <section id="posts" class="flex flex-col gap-4">
            <h2 class="text-2xl font-semibold">
                {
                    lang === "es"
                        ? "Posts sobre este proyecto"
                        : "Posts about this project"
                }
            </h2>
            {
                relatedPosts.length > 0 ? (
                    <div class="flex flex-col gap-2">
                        {relatedPosts.map((post) => (
                            <PostTile post={post} lang={lang} />
                        ))}
                    </div>
                ) : (
                    <p class="text-neutral-300">
                        {lang === "es"
                            ? "Todavía no hay posts sobre este proyecto."
                            : "No posts about this project yet."}
                    </p>
                )
            }
        </section>
    </article>
</MainLayout>
<style is:inline>
    ul {
        list-style-type: disc;
        margin-left: 1.5rem;
        margin-bottom: 1rem;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    li {
        display: list-item;
    }

    .project-divider {
        height: 1px;
        width: 100%;
        background: linear-gradient(
            90deg,
            rgba(255, 255, 255, 0.05),
            rgba(255, 255, 255, 0.3),
            rgba(255, 255, 255, 0.05)
        );
    }
</style>
